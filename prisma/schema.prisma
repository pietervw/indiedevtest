generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AppCategory {
  game
  utility
  productivity
}

enum Platform {
  android
  ios
}

enum AppListingStatus {
  draft
  open_for_testing
  closed_for_testing
  testing_complete
  launched
}

enum TesterRequestStatus {
  pending
  accepted
  rejected
  expired
}

enum TestAssignmentStatus {
  active
  completed
  incomplete
  cancelled
}

enum TesterActivityType {
  requested
  approved
  invitation_resent
  joined
  completed
  withdrew
  declined
  decline_reversed
}

enum TesterFeedbackSeverity {
  low
  medium
  high
  critical
}

enum TesterFeedbackStatus {
  unresolved
  fixed
  skipped
}

enum ListingModerationStatus {
  visible
  hidden
  removed
}

enum ListingReportReason {
  spam_or_scam
  inappropriate_content
  broken_or_misleading_link
  impersonation
  other
}

enum ListingReportStatus {
  open
  dismissed
}

enum BadgeType {
  first_12
  super_tester
  helpful_dev
}

model User {
  id                    String    @id @default(cuid())
  clerkId               String    @unique @map("clerk_id")
  githubId              String?   @unique @map("github_id")
  profileSlug           String    @unique @map("profile_slug")
  githubUsername        String?   @unique @map("github_username")
  githubLogin           String?   @unique @map("github_login")
  displayName           String    @map("display_name")
  imageUrl              String?   @map("image_url")
  contactEmail          String?   @map("contact_email")
  bio                   String?
  twitterHandle         String?   @map("twitter_handle")
  trustMrrProfileUrl    String?   @map("trustmrr_profile_url")
  profileScoreJoined    Int       @default(0) @map("profile_score_joined")
  profileScoreCompleted Int       @default(0) @map("profile_score_completed")
  reviewsWrittenCount   Int       @default(0) @map("reviews_written_count")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  profileCompletedAt    DateTime? @map("profile_completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  appListings     AppListing[]
  testerRequests  TesterRequest[]
  testAssignments TestAssignment[]
  reviews         Review[]
  badges          UserBadge[]
  reportsFiled    ListingReport[] @relation("ReportedListings")
  reportsResolved ListingReport[] @relation("ResolvedListingReports")
  testerActivities TesterActivity[]
  testerFeedback   TesterFeedback[]

  @@map("users")
}

model AppListing {
  id                    String           @id @default(cuid())
  userId                String           @map("user_id")
  name                  String
  logoUrl               String           @map("logo_url")
  description           String
  category              AppCategory
  platform              Platform
  status                AppListingStatus @default(draft)
  moderationStatus      ListingModerationStatus @default(visible) @map("moderation_status")
  storeLink             String?          @map("store_link")
  testingAccessUrl      String?          @map("testing_access_url")
  testerInstructions    String?          @map("tester_instructions")
  /// Optional number of testers this program needs. Accepted requests consume
  /// a place whether or not the developer has subsequently marked them joined.
  testerCapacity        Int?             @map("tester_capacity")
  autoClosedForCapacity Boolean          @default(false) @map("auto_closed_for_capacity")
  maxTestersPerPlatform Int              @default(14) @map("max_testers_per_platform")
  reminderSentAt        DateTime?        @map("reminder_sent_at")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  testerRequests  TesterRequest[]
  testAssignments TestAssignment[]
  reviews         Review[]
  reports         ListingReport[]
  testerActivities TesterActivity[]
  testerFeedback   TesterFeedback[]
  screenshots     AppListingScreenshot[]
  screenshotUploads AppListingScreenshotUpload[]

  @@index([status])
  @@index([userId])
  @@map("app_listings")
}

model AppListingScreenshot {
  id           String   @id @default(cuid())
  appListingId String   @map("app_listing_id")
  objectKey    String   @unique @map("object_key")
  publicUrl    String   @map("public_url")
  sortOrder    Int      @default(0) @map("sort_order")
  width        Int
  height       Int
  byteSize     Int      @map("byte_size")
  contentType  String   @map("content_type")
  createdAt    DateTime @default(now()) @map("created_at")

  appListing AppListing @relation(fields: [appListingId], references: [id], onDelete: Cascade)

  @@index([appListingId, sortOrder])
  @@map("app_listing_screenshots")
}

/// Presigned upload slots not yet confirmed. Counted toward the per-listing
/// screenshot cap until expiry; expired rows are purged (and R2 keys deleted)
/// lazily on the next mint for that listing.
model AppListingScreenshotUpload {
  id           String   @id @default(cuid())
  appListingId String   @map("app_listing_id")
  objectKey    String   @unique @map("object_key")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  appListing AppListing @relation(fields: [appListingId], references: [id], onDelete: Cascade)

  @@index([appListingId, expiresAt])
  @@map("app_listing_screenshot_uploads")
}

/// Durable outbox of R2 keys that must be deleted. Enqueued in the same
/// transaction as cascade-deleting screenshot rows so a transient R2 error
/// (or crash mid-delete) cannot permanently orphan public objects.
model StorageObjectDeletion {
  id            String    @id @default(cuid())
  objectKey     String    @unique @map("object_key")
  attempts      Int       @default(0)
  lastError     String?   @map("last_error") @db.VarChar(500)
  lastAttemptAt DateTime? @map("last_attempt_at")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([nextAttemptAt])
  @@map("storage_object_deletions")
}

model ListingReport {
  id           String              @id @default(cuid())
  appListingId String              @map("app_listing_id")
  reporterId   String              @map("reporter_id")
  reason       ListingReportReason
  details      String?
  status       ListingReportStatus @default(open)
  resolvedAt   DateTime?           @map("resolved_at")
  resolvedById String?             @map("resolved_by_id")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  appListing AppListing @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  reporter   User       @relation("ReportedListings", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("ResolvedListingReports", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([appListingId, status])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
  @@map("listing_reports")
}

model TesterRequest {
  id               String              @id @default(cuid())
  appListingId     String              @map("app_listing_id")
  testerUserId     String              @map("tester_user_id")
  testerEmail      String              @map("tester_email")
  status           TesterRequestStatus @default(pending)
  expiresAt        DateTime            @map("expires_at")
  testAssignmentId String?             @unique @map("test_assignment_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  appListing     AppListing      @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  tester         User            @relation(fields: [testerUserId], references: [id], onDelete: Cascade)
  testAssignment TestAssignment? @relation(fields: [testAssignmentId], references: [id])
  withdrawnAt     DateTime?      @map("withdrawn_at")
  activities      TesterActivity[]

  @@unique([appListingId, testerUserId])
  @@index([testerUserId])
  @@index([status])
  @@map("tester_requests")
}

model TesterActivity {
  id              String             @id @default(cuid())
  appListingId    String             @map("app_listing_id")
  testerRequestId String             @map("tester_request_id")
  testerUserId    String             @map("tester_user_id")
  type            TesterActivityType
  createdAt       DateTime           @default(now()) @map("created_at")

  appListing    AppListing    @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  testerRequest TesterRequest @relation(fields: [testerRequestId], references: [id], onDelete: Cascade)
  tester        User          @relation(fields: [testerUserId], references: [id], onDelete: Cascade)

  @@index([appListingId, createdAt])
  @@index([testerRequestId, createdAt])
  @@map("tester_activities")
}

model TesterFeedback {
  id           String                 @id @default(cuid())
  appListingId String                 @map("app_listing_id")
  testerUserId String                 @map("tester_user_id")
  severity     TesterFeedbackSeverity
  title        String
  details      String
  steps        String?
  device       String?
  status       TesterFeedbackStatus @default(unresolved)
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  appListing AppListing @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  tester     User       @relation(fields: [testerUserId], references: [id], onDelete: Cascade)

  @@index([appListingId, createdAt])
  @@index([testerUserId, createdAt])
  @@map("tester_feedback")
}

model TestAssignment {
  id           String               @id @default(cuid())
  appListingId String               @map("app_listing_id")
  testerUserId String               @map("tester_user_id")
  platform     Platform
  joinedAt     DateTime             @map("joined_at")
  completedAt  DateTime?            @map("completed_at")
  status       TestAssignmentStatus @default(active)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  appListing    AppListing     @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  tester        User           @relation(fields: [testerUserId], references: [id], onDelete: Cascade)
  testerRequest TesterRequest?

  @@unique([appListingId, testerUserId])
  @@index([testerUserId])
  @@index([status])
  /** Speeds homepage/browse counts: JOIN … ON app_listing_id AND status IN (…) */
  @@index([appListingId, status])
  @@map("test_assignments")
}

model Review {
  id           String   @id @default(cuid())
  appListingId String   @map("app_listing_id")
  testerUserId String   @map("tester_user_id")
  content      String
  createdAt    DateTime @default(now()) @map("created_at")

  appListing AppListing @relation(fields: [appListingId], references: [id], onDelete: Cascade)
  tester     User       @relation(fields: [testerUserId], references: [id], onDelete: Cascade)

  @@unique([appListingId, testerUserId])
  @@map("reviews")
}

model UserBadge {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  badgeType BadgeType @map("badge_type")
  earnedAt  DateTime  @default(now()) @map("earned_at")
  metadata  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@map("user_badges")
}
