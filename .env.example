# ── Public site URL (no www) ───────────────────────────────────────────
# Used for canonical URLs, sitemap, Open Graph, robots.txt, and llms.txt.
# Coolify/Docker: set this in the service environment to https://indiedevtest.com
NEXT_PUBLIC_SITE_URL=https://indiedevtest.com

# ── Contact form (SendGrid email delivery) ─────────────────────────────
# Create an API key: https://app.sendgrid.com/settings/api_keys
# (Mail Send permission). Verify domain auth for indiedevtest.com.
SENDGRID_API_KEY=SG.replace_me

# Verified From: address (domain-authenticated sender).
SENDGRID_FROM_EMAIL=admin@indiedevtest.com

# Inbox for contact-form messages and waitlist signup alerts (not shown on the site).
CONTACT_TO_EMAIL=contact@indiedevtest.com

# ── Cloudflare Turnstile (bot protection on contact + waitlist forms) ──
# Create a widget: https://dash.cloudflare.com → Turnstile → Add widget
# Managed mode; hostnames: localhost, 127.0.0.1, indiedevtest.com
# (add www.indiedevtest.com only if you keep it temporarily during DNS cutover)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...
# Site key ≠ secret key — copy both from the same Turnstile widget in the dashboard.
# Local Always Pass keys (dev only):
#   site   1x00000000000000000000AA
#   secret 1x0000000000000000000000000000000AA

# ── Umami analytics (optional) ─────────────────────────────────────────
# Self-hosted tracker script URL and website id. Both required to enable.
# Example src: https://analytics.example.com/script.js
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Pushover ops alerts (optional) ─────────────────────────────────────
# Same env names across Seal Labs apps. Both required to enable.
# Notifies on first-time user signups, waitlist signups, and contact form
# submissions (all fire-and-forget).
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# ── Moderation (admin-only report queue) ───────────────────────────────
# Comma-separated Clerk user IDs permitted to review /admin/reports.
ADMIN_CLERK_USER_IDS=user_...

# ── Cron / scheduled jobs ──────────────────────────────────────────────
# Shared secret for scheduler-triggered routes (Authorization: Bearer …).
# Generate a long random string; required for /api/cron/* endpoints.
CRON_SECRET=replace_with_long_random_secret
# Coolify (Scheduled Task examples):
#   curl -fsS -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     "$NEXT_PUBLIC_SITE_URL/api/cron/listing-14-day-reminders"
#   curl -fsS -X POST -H "Authorization: Bearer $CRON_SECRET" \
#     "$NEXT_PUBLIC_SITE_URL/api/cron/storage-object-deletions"

# ── Database (Neon + Prisma) ───────────────────────────────────────────
# Neon Console → Connect: use the pooled URL for the app, direct for CLI.
# Pooled host includes `-pooler` (Prisma Client via @prisma/adapter-neon).
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooler) host for `prisma migrate` / `db push`.
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Cloudflare R2 object storage (required) ────────────────────────────
# Bucket: indiedevtest
# Object key prefixes (app convention):
#   listings/       → app listing screenshots
#   test-feedback/  → tester evidence screenshots (feature #2)
# Dashboard: create API token with Object Read & Write on this bucket.
# Enable public access (custom domain preferred). After changing r2-cors.json,
# re-apply with: npm run apply:r2-cors (loads .env.local; or paste into R2 Dashboard → CORS).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=indiedevtest
# Public base URL with no trailing slash (custom domain or *.r2.dev).
# Example: https://media.indiedevtest.com
R2_PUBLIC_BASE_URL=https://media.example.com
# Docker image builds without runtime secrets may set ALLOW_MISSING_R2=1
# (only when NODE_ENV is not production). Coolify runtime must NOT set this.
# ALLOW_MISSING_R2=

# ── Clerk (email and optional GitHub OAuth) ─────────────────────────────
# Dashboard: https://dashboard.clerk.com → API Keys + configure email plus
# any desired social providers (GitHub is optional in the app).
# Hosted components live at /sign-in and /sign-up in this app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# ── Sentry error monitoring + performance tracing (optional) ───────────
# Set either DSN to enable event capture. NEXT_PUBLIC_SENTRY_DSN is required for browser events.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Optional: enables source map upload during CI/CD builds. Builds still pass without these.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
