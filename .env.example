# ── Contact form (SendGrid email delivery) ──────────────────────────────
# Create an API key: https://app.sendgrid.com/settings/api_keys (Mail Send > Restricted or Full)
SENDGRID_API_KEY=SG.replace_me

# A VERIFIED sender identity in your SendGrid account:
# https://app.sendgrid.com/settings/senders (single sender) or domain auth.
# This is the From: address on contact emails.
SENDGRID_FROM_EMAIL=noreply@indiedevtest.io

# The inbox that receives contact-form messages (your email).
CONTACT_TO_EMAIL=you@example.com
