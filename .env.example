# ── Contact form (SendGrid email delivery) ──────────────────────────────
# Create an API key: https://app.sendgrid.com/settings/api_keys (Mail Send > Restricted or Full)
SENDGRID_API_KEY=SG.replace_me

# A VERIFIED sender identity in your SendGrid account:
# https://app.sendgrid.com/settings/senders (single sender) or domain auth.
# This is the From: address on contact emails.
SENDGRID_FROM_EMAIL=noreply@indiedevtest.io

# The inbox that receives contact-form messages (your email).
CONTACT_TO_EMAIL=you@example.com

# ── Cloudflare Turnstile (bot protection on the contact form) ──────────
# Create a widget: https://dash.cloudflare.com → Turnstile → Add widget
# (managed mode; domains: localhost, 127.0.0.1, indiedevtest.io)
# Public site key — safe to expose, used in the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# Secret key — SERVER-SIDE ONLY. Never expose to the client or commit.
TURNSTILE_SECRET_KEY=0x4AAAAAAA...
# Local dev test keys (always pass): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA

