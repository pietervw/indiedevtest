# ── Public site URL (no www) ───────────────────────────────────────────
# Used for canonical URLs, sitemap, Open Graph, robots.txt, and llms.txt.
# Coolify/Docker: set this in the service environment to https://indiedevtest.com
NEXT_PUBLIC_SITE_URL=https://indiedevtest.com

# ── Contact form (SendGrid email delivery) ─────────────────────────────
# Create an API key: https://app.sendgrid.com/settings/api_keys
# (Mail Send permission). Verify domain auth for indiedevtest.com.
SENDGRID_API_KEY=SG.replace_me

# Verified From: address (domain-authenticated sender).
SENDGRID_FROM_EMAIL=admin@indiedevtest.com

# Inbox for contact-form messages and waitlist signup alerts (not shown on the site).
CONTACT_TO_EMAIL=contact@indiedevtest.com

# ── Cloudflare Turnstile (bot protection on contact + waitlist forms) ──
# Create a widget: https://dash.cloudflare.com → Turnstile → Add widget
# Managed mode; hostnames: localhost, 127.0.0.1, indiedevtest.com
# (add www.indiedevtest.com only if you keep it temporarily during DNS cutover)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...
# Site key ≠ secret key — copy both from the same Turnstile widget in the dashboard.
# Local Always Pass keys (dev only):
#   site   1x00000000000000000000AA
#   secret 1x0000000000000000000000000000000AA

# ── Umami analytics (optional) ─────────────────────────────────────────
# Self-hosted tracker script URL and website id. Both required to enable.
# Example src: https://analytics.example.com/script.js
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# ── Pushover ops alerts (optional) ─────────────────────────────────────
# Same env names across Seal Labs apps. Both required to enable.
# Notifies on new waitlist signups and contact form submissions (fire-and-forget).
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=

# ── Database (Neon + Prisma) ───────────────────────────────────────────
# Neon Console → Connect: use the pooled URL for the app, direct for CLI.
# Pooled host includes `-pooler` (Prisma Client via @prisma/adapter-neon).
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooler) host for `prisma migrate` / `db push`.
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Clerk (GitHub OAuth + Account Portal) ──────────────────────────────
# Dashboard: https://dashboard.clerk.com → API Keys + Social (GitHub only).
# Production: use Account Portal at accounts.indiedevtest.com (do NOT set
# NEXT_PUBLIC_CLERK_SIGN_IN_URL / SIGN_UP_URL — those force custom app pages).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
